# =============================================================
# Deriv Quant Research & Execution Platform — Environment Config
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# =============================================================

# --- Deriv API ---
# Get your API token from: https://app.deriv.com/account/api-token
Deriv_Api_Token=your_deriv_api_token_here

# --- Database ---
PGUSER=quantuser
PGPASSWORD=change_this_strong_password
PGDATABASE=deriv_quant
# Full connection string (auto-built from above in compose, or set manually)
# DATABASE_URL=postgresql://quantuser:password@localhost:5432/deriv_quant

# --- Trading Mode ---
# Set to "true" ONLY when you are ready for real money execution
# Platform runs in paper mode by default — safe to leave false
LIVE_TRADING_ENABLED=false

# --- Capital & Risk Settings ---
# These are stored in DB platform_state after first run
# Set them via the Risk dashboard page
# MAX_DAILY_LOSS_PCT=3
# MAX_WEEKLY_LOSS_PCT=8
# MAX_DRAWDOWN_PCT=15
# INITIAL_CAPITAL=10000
# WITHDRAWAL_THRESHOLD=15000

# --- Symbols to Monitor ---
# Comma-separated list of Deriv symbols
# SYMBOLS=BOOM1000,CRASH1000,BOOM500,CRASH500

# --- Server ---
PORT=8080
API_PORT=8080
WEB_PORT=80

# --- Session ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_random_secret_string
